<!DOCTYPE html>
<html lang="si">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sathi AI - Pro Edition</title>
    <link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet">
    
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Google Sans', sans-serif; }
        body { background-color: #131314; color: #e3e3e3; display: flex; height: 100vh; overflow: hidden; }
        
        /* App Layout */
        .app-container { display: flex; width: 100%; height: 100vh; position: relative; }
        
        /* Sidebar (Chat History) Styling */
        aside { width: 280px; background-color: #1e1f20; display: flex; flex-direction: column; padding: 16px; border-right: 1px solid #3c4043; transition: all 0.3s ease; z-index: 5; }
        .new-chat-btn { display: flex; align-items: center; gap: 12px; background-color: #282a2c; border: none; border-radius: 24px; padding: 14px 20px; color: #e3e3e3; font-weight: 500; cursor: pointer; transition: background 0.2s; margin-bottom: 24px; font-size: 14px; width: fit-content; }
        .new-chat-btn:hover { background-color: #37393b; }
        
        .history-section { flex: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 4px; }
        .history-section::-webkit-scrollbar { width: 4px; }
        .history-section::-webkit-scrollbar-thumb { background: #3c4043; border-radius: 2px; }
        .history-title { font-size: 12px; color: #c4c7c5; font-weight: 500; padding: 8px 12px; }
        
        .history-item { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 20px; color: #e3e3e3; cursor: pointer; font-size: 14px; text-decoration: none; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; position: relative; transition: background 0.2s; }
        .history-item:hover, .history-item.active { background-color: #37393b; }
        .delete-chat-btn { position: absolute; right: 8px; color: #c4c7c5; display: none; background: none; border: none; cursor: pointer; }
        .history-item:hover .delete-chat-btn { display: block; }
        .delete-chat-btn:hover { color: #ea4335; }

        /* Main Chat Window */
        main { flex: 1; display: flex; flex-direction: column; height: 100vh; background-color: #131314; position: relative; }
        
        /* Header Styling */
        header { display: flex; align-items: center; justify-content: space-between; padding: 16px 24px; border-bottom: 1px solid #282a2c; }
        .brand { font-size: 22px; font-weight: 500; display: flex; align-items: center; gap: 8px; color: #e3e3e3; }
        .menu-btn { color: #c4c7c5; cursor: pointer; margin-right: 8px; display: none; }
        .auth-status { display: flex; align-items: center; gap: 10px; }
        .owner-badge { background: linear-gradient(135deg, #f1c40f, #f39c12); color: #131314; padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: bold; display: flex; align-items: center; gap: 4px; box-shadow: 0 0 10px rgba(241, 196, 15, 0.3); }
        .login-btn { background: #37393b; border: none; color: #e3e3e3; padding: 8px 16px; border-radius: 18px; cursor: pointer; font-size: 13px; display: flex; align-items: center; gap: 6px; }
        .login-btn:hover { background: #4a4d51; }

        /* Chat Containers */
        .chat-container { flex: 1; overflow-y: auto; padding: 20px 15%; display: flex; flex-direction: column; gap: 32px; }
        .chat-container::-webkit-scrollbar { width: 8px; }
        .chat-container::-webkit-scrollbar-thumb { background: #3c4043; border-radius: 4px; }

        .chat-row { display: flex; gap: 20px; align-items: flex-start; max-width: 850px; width: 100%; margin: 0 auto; animation: fadeIn 0.3s ease; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
        
        /* Avatars */
        .avatar { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
        .user-avatar { background: #37393b; color: white; font-weight: 500; font-size: 15px; }
        .ai-avatar { background: linear-gradient(135deg, #4285f4, #d96570, #9b72cb); color: white; }

        /* Message Content with Custom Markdown Support */
        .message-content { flex: 1; font-size: 16px; line-height: 1.6; color: #e3e3e3; }
        .message-text-block { white-space: pre-wrap; margin-bottom: 8px; }
        
        /* Advanced Code Box / Copy Container */
        .code-container { background-color: #0f0f10; border-radius: 8px; border: 1px solid #3c4043; margin: 16px 0; overflow: hidden; }
        .code-header { background-color: #202124; padding: 8px 16px; display: flex; justify-content: space-between; align-items: center; font-size: 12px; color: #c4c7c5; border-bottom: 1px solid #3c4043; font-family: monospace; text-transform: uppercase; }
        .copy-btn { background: none; border: none; color: #c4c7c5; cursor: pointer; display: flex; align-items: center; gap: 6px; font-size: 12px; padding: 4px 8px; border-radius: 4px; }
        .copy-btn:hover { background-color: #37393b; color: white; }
        .code-container pre { padding: 16px; margin: 0; overflow-x: auto; }
        .code-container code { font-family: 'Courier New', Courier, monospace; font-size: 14px; color: #e3e3e3; white-space: pre; }
        .inline-code { background-color: #2d2f31; padding: 2px 6px; border-radius: 4px; font-family: monospace; font-size: 14px; color: #f2b01f; }

        /* Footer Input Area */
        .footer-container { padding: 20px 15%; background-color: #131314; }
        .input-wrapper { max-width: 850px; margin: 0 auto; display: flex; align-items: center; background-color: #1e1f20; border-radius: 30px; padding: 10px 18px; }
        #userInput { flex: 1; background: none; border: none; outline: none; color: #e3e3e3; font-size: 16px; padding: 8px 12px; }
        #userInput::placeholder { color: #c4c7c5; }
        .send-btn { background: transparent; border: none; color: #c4c7c5; cursor: pointer; padding: 8px; display: flex; align-items: center; justify-content: center; border-radius: 50%; }
        .send-btn:hover { color: #e3e3e3; background-color: #37393b; }
        
        /* Loading Stars */
        .loading-stars { display: flex; gap: 4px; padding-top: 8px; }
        .star { width: 8px; height: 8px; background: linear-gradient(135deg, #4285f4, #d96570); border-radius: 50%; animation: blink 1.4s infinite both; }
        .star:nth-child(1) { animation-delay: -0.32s; }
        .star:nth-child(2) { animation-delay: -0.16s; }
        @keyframes blink { 0%, 80%, 100% { transform: scale(0); opacity: 0.5; } 40% { transform: scale(1); opacity: 1; } }

        /* Login Modal Overlays */
        .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 100; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; }
        .modal-overlay.active { opacity: 1; pointer-events: auto; }
        .login-card { background: #1e1f20; padding: 32px; border-radius: 16px; width: 100%; max-width: 380px; border: 1px solid #3c4043; display: flex; flex-direction: column; gap: 16px; }
        .login-card h3 { font-size: 20px; font-weight: 500; color: #e3e3e3; text-align: center; margin-bottom: 8px; }
        .login-card input { background: #131314; border: 1px solid #3c4043; border-radius: 8px; padding: 12px; color: white; font-size: 15px; outline: none; }
        .login-card input:focus { border-color: #4285f4; }
        .login-card button { background: #4285f4; border: none; color: white; padding: 12px; border-radius: 8px; font-size: 15px; font-weight: 500; cursor: pointer; margin-top: 8px; }
        .login-card button:hover { background: #357ae8; }
        .close-modal { text-align: center; color: #c4c7c5; font-size: 13px; cursor: pointer; text-decoration: underline; }

        /* Mobile Responsive adjustment */
        @media (max-width: 768px) {
            aside { position: absolute; left: -280px; height: 100%; }
            aside.open { left: 0; }
            .menu-btn { display: block; }
            .chat-container, .footer-container { padding: 16px 5%; }
        }
    </style>
</head>
<body>

    <div class="app-container">
        <aside id="sidebar">
            <button class="new-chat-btn" onclick="startNewChat()">
                <span class="material-icons-outlined">add</span> New chat
            </button>
            <div class="history-title">Recent Chats</div>
            <div class="history-section" id="chatList"></div>
        </aside>

        <main>
            <header>
                <div style="display: flex; align-items: center;">
                    <span class="material-icons-outlined menu-btn" onclick="toggleSidebar()">menu</span>
                    <div class="brand">
                        <span class="material-icons-outlined" style="background: linear-gradient(135deg, #4285f4, #d96570, #9b72cb); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">auto_awesome</span>
                        Sathi AI
                    </div>
                </div>
                <div class="auth-status" id="authArea"></div>
            </header>

            <div class="chat-container" id="chatContainer"></div>

            <div class="footer-container">
                <div class="input-wrapper">
                    <input type="text" id="userInput" placeholder="Ask Sathi AI..." onkeypress="checkEnter(event)">
                    <button class="send-btn" onclick="sendMessage()">
                        <span class="material-icons-outlined">send</span>
                    </button>
                </div>
            </div>
        </main>
    </div>

    <div class="modal-overlay" id="loginModal">
        <div class="login-card">
            <h3>Owner Authentication</h3>
            <input type="text" id="usernameInput" placeholder="Username">
            <input type="password" id="passwordInput" placeholder="Password">
            <button onclick="handleLogin()">Login</button>
            <div class="close-modal" onclick="closeLoginModal()">Cancel</div>
        </div>
    </div>

    <script>
        // API_KEY මෙතන නෑ! Cloudflare Function එකට කතා කරන්නේ මෙතනින්.
        const CLOUDFLARE_API_URL = "/api/chat";

        // Global State variables
        let chatSessions = JSON.parse(localStorage.getItem("sathi_chat_sessions")) || [];
        let activeChatId = localStorage.getItem("sathi_active_chat_id") || null;
        let isOwnerLoggedIn = JSON.parse(localStorage.getItem("sathi_is_owner")) || false;

        // Run on Initial Launch
        window.onload = function() {
            updateAuthUI();
            renderSidebar();
            if (chatSessions.length === 0) {
                startNewChat();
            } else {
                if (!activeChatId) activeChatId = chatSessions[0].id;
                loadChatSession(activeChatId);
            }
        };

        // Chat Management: Start New Session
        function startNewChat() {
            const newSession = {
                id: "chat_" + Date.now(),
                title: "New Chat Session",
                messages: []
            };
            chatSessions.unshift(newSession);
            activeChatId = newSession.id;
            saveState();
            renderSidebar();
            loadChatSession(activeChatId);
        }

        // Chat Management: Load Active Session
        function loadChatSession(id) {
            activeChatId = id;
            localStorage.setItem("sathi_active_chat_id", id);
            
            // Highlight current sidebar item
            document.querySelectorAll('.history-item').forEach(item => {
                item.classList.remove('active');
                if(item.dataset.id === id) item.classList.add('active');
            });

            const currentChat = chatSessions.find(c => c.id === id);
            const container = document.getElementById("chatContainer");
            container.innerHTML = "";

            if (!currentChat || currentChat.messages.length === 0) {
                // Initial Welcome Banner
                container.innerHTML = `
                    <div class="chat-row ai-row">
                        <div class="avatar ai-avatar"><span class="material-icons-outlined" style="font-size:20px;">auto_awesome</span></div>
                        <div class="message-content">
                            <div class="message-text-block">ආයුබෝවන්! මම Sathi AI. මම නිර්මාණය කළේ Viruna Randinu විසිනි. අද මම ඔබට උදව් කරන්නේ කෙසේද? ✨</div>
                        </div>
                    </div>`;
                return;
            }

            currentChat.messages.forEach(msg => {
                renderMessageUI(msg.role, msg.text);
            });
            scrollToBottom();
        }

        // Chat Management: Delete Session
        function deleteChat(id, event) {
            event.stopPropagation();
            chatSessions = chatSessions.filter(c => c.id !== id);
            if (activeChatId === id) {
                activeChatId = chatSessions.length > 0 ? chatSessions[0].id : null;
            }
            saveState();
            renderSidebar();
            if (activeChatId) {
                loadChatSession(activeChatId);
            } else {
                startNewChat();
            }
        }

        // UI Management: Render Sidebar Elements
        function renderSidebar() {
            const listContainer = document.getElementById("chatList");
            listContainer.innerHTML = "";
            chatSessions.forEach(chat => {
                const isActive = chat.id === activeChatId ? "active" : "";
                const item = document.createElement("div");
                item.className = `history-item ${isActive}`;
                item.dataset.id = chat.id;
                item.onclick = () => loadChatSession(chat.id);
                item.innerHTML = `
                    <span class="material-icons-outlined" style="font-size:18px; color:#c4c7c5;">chat_bubble_outline</span>
                    <span style="flex:1; overflow:hidden; text-overflow:ellipsis;">${chat.title}</span>
                    <button class="delete-chat-btn" onclick="deleteChat('${chat.id}', event)">
                        <span class="material-icons-outlined" style="font-size:16px;">delete</span>
                    </button>
                `;
                listContainer.appendChild(item);
            });
        }

        // Advanced Custom RegEx Markdown Syntax Engine
        function parseMarkdown(text) {
            if (!text) return "";
            
            // Security Sanitize HTML tags injection
            let escaped = text.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");

            // Complete Blocks Detection (```lang ... ```)
            const codeBlockRegex = /```([a-zA-Z0-9_\-+]+)?\n([\s\S]*?)\n```/g;
            escaped = escaped.replace(codeBlockRegex, (match, lang, code) => {
                const language = lang || 'code';
                return `</div><div class="code-container">
                            <div class="code-header">
                                <span>${language}</span>
                                <button class="copy-btn" onclick="copyCode(this)">
                                    <span class="material-icons-outlined" style="font-size: 16px;">content_copy</span> Copy
                                </button>
                            </div>
                            <pre><code class="code-content">${code}</code></pre>
                        </div><div class="message-text-block">`;
            });

            // Reconstruct segmented nodes safely
            escaped = `<div class="message-text-block">${escaped}</div>`;
            escaped = escaped.replace(/<div class="message-text-block"><\/div>/g, '');

            // Inline codes detection (`code`)
            escaped = escaped.replace(/`([^`]+)`/g, '<code class="inline-code">$1</code>');

            // Bold styling configuration (**bold**)
            escaped = escaped.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');

            return escaped;
        }

        // Utility: Clipboard Copy Module
        function copyCode(button) {
            const container = button.closest('.code-container');
            const codeText = container.querySelector('.code-content').innerText;
            navigator.clipboard.writeText(codeText).then(() => {
                button.innerHTML = `<span class="material-icons-outlined" style="font-size: 16px;">done</span> Copied!`;
                setTimeout(() => {
                    button.innerHTML = `<span class="material-icons-outlined" style="font-size: 16px;">content_copy</span> Copy`;
                }, 2000);
            });
        }

        // UI Management: Render Message Rows
        function renderMessageUI(role, text) {
            const container = document.getElementById("chatContainer");
            const row = document.createElement("div");
            row.className = `chat-row ${role === 'user' ? 'user-row' : 'ai-row'}`;
            
            if (role === 'user') {
                const initial = isOwnerLoggedIn ? "V" : "U";
                row.innerHTML = `<div class="avatar user-avatar">${initial}</div><div class="message-content"><div class="message-text-block">${text}</div></div>`;
            } else {
                const htmlOutput = parseMarkdown(text);
                row.innerHTML = `<div class="avatar ai-avatar"><span class="material-icons-outlined" style="font-size: 20px;">auto_awesome</span></div><div class="message-content">${htmlOutput}</div>`;
            }
            container.appendChild(row);
        }

        // Network Layer: Send Messaging and Process Context Memory Pipeline
        async function sendMessage() {
            const inputField = document.getElementById("userInput");
            const prompt = inputField.value.trim();
            if (!prompt) return;

            const currentChat = chatSessions.find(c => c.id === activeChatId);
            if (!currentChat) return;

            if (currentChat.messages.length === 0) {
                currentChat.title = prompt.length > 24 ? prompt.substring(0, 24) + "..." : prompt;
                renderSidebar();
            }

            currentChat.messages.push({ role: "user", text: prompt });
            renderMessageUI("user", prompt);
            inputField.value = "";
            saveState();
            scrollToBottom();

            const container = document.getElementById("chatContainer");
            const loadingRow = document.createElement("div");
            loadingRow.className = "chat-row ai-row";
            loadingRow.innerHTML = `
                <div class="avatar ai-avatar"><span class="material-icons-outlined" style="font-size: 20px;">auto_awesome</span></div>
                <div class="message-content">
                    <div class="loading-stars"><div class="star"></div><div class="star"></div><div class="star"></div></div>
                </div>`;
            container.appendChild(loadingRow);
            scrollToBottom();

            const historyPayload = currentChat.messages.map(msg => {
                return {
                    role: msg.role === "user" ? "user" : "model",
                    parts: [{ text: msg.text }]
                };
            });

            try {
                // යවන්නේ අපේ Cloudflare Backend එකට විතරයි! 
                const response = await fetch(CLOUDFLARE_API_URL, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ 
                        historyPayload: historyPayload,
                        isOwnerLoggedIn: isOwnerLoggedIn // Backend එකට අයිතිකරු ද කියලා යවනවා
                    })
                });

                const data = await response.json();
                loadingRow.remove();

                if (data.reply) {
                    currentChat.messages.push({ role: "model", text: data.reply });
                    renderMessageUI("model", data.reply);
                    saveState();
                } else if (data.error) {
                    renderMessageUI("model", `⚠️ Error Occurred: ${data.error}`);
                }
                scrollToBottom();
            } catch (error) {
                loadingRow.remove();
                renderMessageUI("model", `⚠️ Network Error. Connection lost.`);
                scrollToBottom();
            }
        }

        // Authentication Module Layer Functions
        function openLoginModal() { document.getElementById("loginModal").classList.add("active"); }
        function closeLoginModal() { document.getElementById("loginModal").classList.remove("active"); }
        
        function handleLogin() {
            const user = document.getElementById("usernameInput").value.trim();
            const pass = document.getElementById("passwordInput").value.trim();

            if (user === "Viruna" && pass === "123") {
                isOwnerLoggedIn = true;
                localStorage.setItem("sathi_is_owner", true);
                closeLoginModal();
                updateAuthUI();
                
                document.getElementById("usernameInput").value = "";
                document.getElementById("passwordInput").value = "";
                
                loadChatSession(activeChatId);
            } else {
                alert("වැරදි දත්ත! ඔබ සත්‍ය අයිතිකරු නොවේ නම් කරුණාකර ඉවත් වන්න.");
            }
        }

        function handleLogout() {
            isOwnerLoggedIn = false;
            localStorage.setItem("sathi_is_owner", false);
            updateAuthUI();
            loadChatSession(activeChatId);
        }

        function updateAuthUI() {
            const authArea = document.getElementById("authArea");
            if (isOwnerLoggedIn) {
                authArea.innerHTML = `
                    <div class="owner-badge"><span class="material-icons-outlined" style="font-size:16px;">workspace_premium</span> Owner Mode Active</div>
                    <button class="login-btn" onclick="handleLogout()" style="background:#ea4335;"><span class="material-icons-outlined" style="font-size:16px;">logout</span> Logout</button>
                `;
            } else {
                authArea.innerHTML = `
                    <button class="login-btn" onclick="openLoginModal()">
                        <span class="material-icons-outlined" style="font-size: 18px;">admin_panel_settings</span> Owner Login
                    </button>
                `;
            }
        }

        // Basic States Handling
        function saveState() {
            localStorage.setItem("sathi_chat_sessions", JSON.stringify(chatSessions));
            localStorage.setItem("sathi_active_chat_id", activeChatId);
        }
        function scrollToBottom() {
            const container = document.getElementById("chatContainer");
            container.scrollTop = container.scrollHeight;
        }
        function checkEnter(event) { if (event.key === "Enter") sendMessage(); }
        function toggleSidebar() { document.getElementById("sidebar").classList.toggle("open"); }
    </script>
</body>
</html>
